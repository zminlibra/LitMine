# LitMine Backend Configuration
# Copy this file to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://litmine:litmine_dev@localhost:5432/litmine
DATABASE_URL_SYNC=postgresql://litmine:litmine_dev@localhost:5432/litmine

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=litmine_kg

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=litmine_admin
S3_SECRET_KEY=litmine_minio_dev
S3_BUCKET=litmine

# GROBID
GROBID_URL=http://localhost:8070

# LLM (LiteLLM)
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=sk-ant-your-key-here
EMBEDDING_MODEL=text-embedding-3-small

# JWT
SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Debug
DEBUG=true
